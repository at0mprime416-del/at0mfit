# At0m Fit — Environment Variables
# Copy this file to .env.local and fill in values.
# NEVER commit real values to git.
# In Replit: add these via the Secrets tab (not as plain env vars).

# ── Supabase (Frontend — anon key, safe in browser) ──────────────────────────
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# ── Supabase (Server-side ONLY — never expose in frontend) ───────────────────
SUPABASE_SERVICE_ROLE_KEY=

# ── Email (Nodemailer / Gmail SMTP) ─────────────────────────────────────────
# Used by /api/waitlist-confirm to send confirmation emails
GMAIL_USER=
GMAIL_APP_PASSWORD=

# ── Payments ─────────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# ── Gumroad (Blueprint product delivery) ─────────────────────────────────────
GUMROAD_ACCESS_TOKEN=

# ── Notifications ─────────────────────────────────────────────────────────────
DISCORD_WEBHOOK_URL=

# ── Runtime (set automatically by Replit — do not set manually) ──────────────
# PORT=
# BASE_PATH=
