# At0m Fit — Environment Variables
# Copy this file to .env.local and fill in values.
# NEVER commit real values to git.
# In Replit: add these via the Secrets tab (not as plain env vars).

# ── Supabase (Frontend) ──────────────────────────────────────────────────────
# Public/anon key — safe to use in frontend code
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# ── Supabase (Server / API) ──────────────────────────────────────────────────
# Service role key — server-side only, NEVER expose in frontend
# SUPABASE_SERVICE_ROLE_KEY=

# ── Email (Nodemailer / Gmail SMTP) ─────────────────────────────────────────
# Used by /api/waitlist-confirm to send confirmation emails
GMAIL_USER=
GMAIL_APP_PASSWORD=

# ── Runtime (set automatically by Replit workflow) ───────────────────────────
# Do not set these manually — Replit injects them per artifact
# PORT=
# BASE_PATH=

# ── AI Coach (add when porting /coach route) ─────────────────────────────────
# OPENAI_API_KEY=
# (or whichever AI provider powers /coach)
