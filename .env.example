# AT0M FIT — Environment Variables
# Copy to .env.local and fill in values.
# NEVER commit real values to git.
# In Replit: add via the Secrets tab only.

# ── Supabase (Frontend — anon key, safe in browser) ──────────────────────────
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# ── Supabase (Server-side ONLY — NEVER expose in frontend) ───────────────────
SUPABASE_SERVICE_ROLE_KEY=

# ── Email (Nodemailer / Gmail SMTP) ─────────────────────────────────────────
# Used by: /api/waitlist-confirm and /api/notify-coach
GMAIL_USER=
GMAIL_APP_PASSWORD=

# ── Coach Notification Recipient ─────────────────────────────────────────────
# Defaults to jeshua@levioperations.com if not set
NOTIFICATION_TO_EMAIL=

# ── Payments ─────────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# ── Gumroad (Blueprint product delivery) ─────────────────────────────────────
GUMROAD_ACCESS_TOKEN=

# ── AI (Ask AT0M — optional, falls back to contextual responses if missing) ───
OPENAI_API_KEY=

# ── Notifications ─────────────────────────────────────────────────────────────
DISCORD_WEBHOOK_URL=

# ── Runtime (set automatically by Replit — do not set manually) ──────────────
# PORT=
# BASE_PATH=
