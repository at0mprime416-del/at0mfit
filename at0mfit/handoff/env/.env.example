# AT0M FIT — Environment Variables
# Copy this file and fill in real values.
# NEVER commit real values to GitHub.
# Set these as Replit Secrets (Settings → Secrets panel).

# ── SUPABASE ──────────────────────────────────────────────────────────────────
# Project URL: https://supabase.com/dashboard/project/kgozddcutazpqmfbzafa/settings/api
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_DB_PASSWORD=

# Note: SUPABASE_ANON_KEY is also hardcoded in portal.html and coach.html.
# It is the public key and safe to expose in browser JS.
# SUPABASE_SERVICE_ROLE_KEY must NEVER appear in any frontend file.

# ── VERCEL ────────────────────────────────────────────────────────────────────
# Token: https://vercel.com/account/tokens
VERCEL_TOKEN=
VERCEL_PROJECT_ID=prj_mwytZpFWdELjcVOceVV0PlJ446jr

# ── OPENAI ────────────────────────────────────────────────────────────────────
# Used by mobile app (aiGoals.js) for AI workout generation
# Model: gpt-4o
OPENAI_API_KEY=

# ── GOOGLE MAPS ───────────────────────────────────────────────────────────────
# Used by mobile app for GPS run tracking (LiveRunScreen.js)
# Configured in app.json for iOS + Android
GOOGLE_MAPS_API_KEY=

# ── EMAIL (RESEND) ────────────────────────────────────────────────────────────
# For client onboarding emails and application notifications (future)
RESEND_API_KEY=

# ── STRIPE (FUTURE) ───────────────────────────────────────────────────────────
# Not integrated yet. Activate at 10+ clients.
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_ID=

# ── MOBILE APP (EXPO) ─────────────────────────────────────────────────────────
# These are also set in at0mfit-app/.env (not committed)
# EXPO_PUBLIC_ prefix makes them available in Expo client-side code
EXPO_PUBLIC_SUPABASE_URL=
EXPO_PUBLIC_SUPABASE_ANON_KEY=
EXPO_PUBLIC_OPENAI_API_KEY=

# ── OPTIONAL / MONITORING ─────────────────────────────────────────────────────
# AgentOps: OpenClaw usage only — not needed in Replit
# AGENTOPS_API_KEY=
